<?php /** @var View $this **/ ?>

<?php
        $link_buttons = [
            ['name'=>$this->_('Proxmox.add_module_row', true), 'attributes'=>['href'=>$this->base_uri . 'settings/company/modules/addrow/' . $module->id]],
            ['name'=>$this->_('Proxmox.add_module_group', true), 'attributes'=>['href'=>$this->base_uri . 'settings/company/modules/addgroup/' . $module->id]]
        ];

        $this->Widget->clear();
        $this->Widget->setLinkButtons($link_buttons);

        $this->Widget->create($this->_('AdminCompanyModules.manage.boxtitle_manage', true, (isset($module->name) ? $this->Html->safe($module->name) : null)), ['id'=>'manage_proxmox']);
        ?>

<h6 class="form-section-header first"><?php $this->_('Proxmox.manage.module_rows_title');?></h6>
        <?php
        $num_rows = count((isset($module->rows) ? $module->rows : []));
        if ($num_rows > 0) {
        ?>
<table class="table">
    <thead>
        <tr>
            <th><span><?php $this->_('Proxmox.manage.module_rows_heading.server_label');?></span></th>
            <th><span><?php $this->_('Proxmox.manage.module_rows_heading.host');?></span></th>
            <th><span><?php $this->_('Proxmox.manage.module_rows_heading.options');?></span></th>
        </tr>
    </thead>
    <tbody>
        <?php

            for ($i=0; $i<$num_rows; $i++) {
            ?>
        <tr>
            <td><?php echo (isset($module->rows[$i]->meta->server_name) ? $this->Html->safe($module->rows[$i]->meta->server_name) : null);?></td>
            <td><?php echo (isset($module->rows[$i]->meta->host) ? $this->Html->safe($module->rows[$i]->meta->host) : null);?></td>
            <td>
                <a href="<?php echo $this->Html->safe($this->base_uri . 'settings/company/modules/editrow/' . (isset($module->id) ? $module->id : null) . '/' . (isset($module->rows[$i]->id) ? $module->rows[$i]->id : null) . '/');?>" class="btn btn-sm btn-outline-secondary" title="<?php $this->_('Proxmox.manage.module_rows.edit');?>">
                    <i class="bi bi-pencil"></i>
                </a>
                <?php                    $this->Form->create($this->base_uri . 'settings/company/modules/deleterow/', ['class' => 'd-inline']);
                    $this->Form->fieldHidden('id', (isset($module->id) ? $module->id : null));
                    $this->Form->fieldHidden('row_id', (isset($module->rows[$i]->id) ? $module->rows[$i]->id : null));
                    ?>
                <button type="button" class="btn btn-sm btn-outline-danger modal-confirm-delete"
                    data-confirm-message="<?php echo $this->Html->safe($this->_('Proxmox.manage.module_rows.confirm_delete', true));?>"
                    title="<?php $this->_('Proxmox.manage.module_rows.delete');?>">
                    <i class="bi bi-trash"></i>
                </button>
                <?php
                    $this->Form->end();
                    ?>
            </td>
        </tr>
                <?php
            }
            ?>
    </tbody>
</table>
                <?php
        } else {
        ?>
<div class="card-body text-center text-muted py-5">
    <i class="bi bi-server" style="font-size: 3rem; opacity: 0.3;"></i>
    <p class="mt-3 mb-0"><?php $this->_('Proxmox.manage.module_rows_no_results');?></p>
</div>
                <?php
        }
        ?>

<div class="title_row">
    <h6 class="form-section-header mt-4"><?php $this->_('Proxmox.manage.module_groups_title');?></h6>
</div>
                <?php
        $num_rows = count((isset($module->groups) ? $module->groups : []));
        if ($num_rows > 0) {
        ?>
<table class="table">
    <thead>
        <tr>
            <th><span><?php $this->_('Proxmox.manage.module_groups_heading.name');?></span></th>
            <th><span><?php $this->_('Proxmox.manage.module_groups_heading.servers');?></span></th>
            <th><span><?php $this->_('Proxmox.manage.module_groups_heading.options');?></span></th>
        </tr>
    </thead>
    <tbody>
        <?php

            for ($i=0; $i<$num_rows; $i++) {
            ?>
        <tr>
            <td><?php echo (isset($module->groups[$i]->name) ? $this->Html->safe($module->groups[$i]->name) : null);?></td>
            <td><?php echo count((isset($module->groups[$i]->rows) ? $module->groups[$i]->rows : []));?></td>
            <td>
                <a href="<?php echo $this->Html->safe($this->base_uri . 'settings/company/modules/editgroup/' . (isset($module->id) ? $module->id : null) . '/' . (isset($module->groups[$i]->id) ? $module->groups[$i]->id : null) . '/');?>" class="btn btn-sm btn-outline-secondary" title="<?php $this->_('Proxmox.manage.module_groups.edit');?>">
                    <i class="bi bi-pencil"></i>
                </a>
                <?php
                    $this->Form->create($this->base_uri . 'settings/company/modules/deletegroup/', ['class' => 'd-inline']);
                    $this->Form->fieldHidden('id', (isset($module->id) ? $module->id : null));
                    $this->Form->fieldHidden('group_id', (isset($module->groups[$i]->id) ? $module->groups[$i]->id : null));
                    ?>
                <button type="button" class="btn btn-sm btn-outline-danger modal-confirm-delete"
                    data-confirm-message="<?php echo $this->Html->safe($this->_('Proxmox.manage.module_groups.confirm_delete', true));?>"
                    title="<?php $this->_('Proxmox.manage.module_groups.delete');?>">
                    <i class="bi bi-trash"></i>
                </button>
                <?php
                    $this->Form->end();
                    ?>
            </td>
        </tr>
                <?php
            }
            ?>
    </tbody>
</table>
                <?php
        } else {
        ?>
<div class="card-body text-center text-muted py-5">
    <i class="bi bi-collection" style="font-size: 3rem; opacity: 0.3;"></i>
    <p class="mt-3 mb-0"><?php $this->_('Proxmox.manage.module_groups_no_results');?></p>
</div>
                <?php
        }

        $this->Widget->end();
        ?>

<script type="text/javascript">
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof blestaModalConfirm === 'function') {
            blestaModalConfirm('.modal-confirm-delete');
        }
    });
</script>